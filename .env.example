# Copy to `.env` and adjust paths (`.env` is gitignored).
#
# `AGC_ARCHIVE_PATH` is read from this file by Demo.kt and the real-world benchmarks (via java-dotenv).
# `AGC_BENCHMARK_CLI_CHUNK_SIZE` and `AGC_BENCHMARK_CONTIG` are read from `.env` by FullChrRegionsBenchmark (same loader).
# Other `AGC_BENCHMARK_*` variables use `System.getenv` — export them, use IDE env injection,
# or a wrapper that loads `.env` into the environment before `./gradlew`.

# Path to an AGC archive for demos and real-world benchmarks (`benchmarkReal`, `benchmarkFullChrRegions`, `./gradlew demo`).
AGC_ARCHIVE_PATH=/path/to/your/archive.agc

# Toy benchmark only (`./gradlew benchmark`): overrides the bundled fixture when set.
# AGC_BENCHMARK_ARCHIVE=/path/to/toy.agc

# Timing (optional; all benchmarks): outer iterations and warmup rounds. Defaults vary by benchmark.
# AGC_BENCHMARK_ITERATIONS=15
# AGC_BENCHMARK_WARMUP=5

# Output: directory for CSV reports (default build/reports/benchmark-data) and/or explicit CSV path.
# AGC_BENCHMARK_REPORT_DIR=build/reports/benchmark-data
# AGC_BENCHMARK_CSV=build/reports/benchmark-data/custom_benchmark.csv

# FullChrRegionsBenchmark (`./gradlew benchmarkFullChrRegions`): `0` = one `agc getctg` with all regions
# (default); `> 0` = at most that many regions per subprocess if argv limits are hit.
# AGC_BENCHMARK_CLI_CHUNK_SIZE=0

# Contig key to tile (leading token, e.g. chr1, chr2). Default chr1.
# AGC_BENCHMARK_CONTIG=chr1
